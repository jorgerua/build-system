# Environment variables for local development with Docker Compose.
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env

# GitHub App — webhook secret (used by webhook-server to validate signatures)
CBS_GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App — App ID (used by worker to generate installation tokens)
CBS_GITHUB_APP_ID=your_app_id_here

# GitHub App — private key PEM file.
# Place the downloaded PEM at local/github-private-key.pem.
# The path below is the mount point inside the worker container; do not change it.
# CBS_GITHUB_PRIVATE_KEY_PATH=/secrets/github.pem  (set automatically in docker-compose.yaml)
